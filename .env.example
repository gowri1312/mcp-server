# Copy to .env for local development (never commit .env)
PORT=8000
AUTH_MODE=apikey
MCP_API_KEY=your-dev-api-key-here

# User-assigned managed identity client ID (set when running in Azure)
MANAGED_IDENTITY_CLIENT_ID=

# Azure SQL
SQL_SERVER=<your-server>.database.windows.net
SQL_DATABASE=<your-database>

# Azure Storage — separate subscription, accessed via account-level SAS token
STORAGE_ACCOUNT_NAME=<your-storage-account>
STORAGE_SAS_TOKEN=<sas-token-without-leading-question-mark-ok-either-way>
